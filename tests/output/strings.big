func main(): int {
  var hello: string = "Hello";
  
  println("%s %d", hello, hello.length());
  println("%s %d", "hello", "hello".length());

  var world: string = " World";
  println("%s", hello + world);

  var exclamation: string = "!";
  println("%s", hello + world + exclamation);

  return 0;
}